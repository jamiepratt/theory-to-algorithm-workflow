{
  "schema_version": 1,
  "repositories": [
    {
      "id": "publication",
      "github": "jamiepratt/clojurecivitas.github.io",
      "path": "clojurecivitas.github.io",
      "role": "Executable research, evidence, tests, and article publication",
      "remote": "origin",
      "commit_order": 1
    },
    {
      "id": "workflow",
      "github": "jamiepratt/theory-to-algorithm-workflow",
      "path": ".",
      "role": "Workflow, decisions, model contract, profile, and reusable skills",
      "remote": "origin",
      "commit_order": 2
    }
  ],
  "submodules": [
    {
      "path": "clojurecivitas.github.io",
      "owner_repository": "workflow",
      "source_repository": "publication",
      "url": "https://github.com/jamiepratt/clojurecivitas.github.io.git",
      "pointer_behavior": "commit-and-publish-source-before-owner-pointer"
    }
  ],
  "articles": {
    "repository": "publication",
    "source_glob": "src/language_learning/vocabulary_estimation/*.clj",
    "source_marker": ":clay",
    "source_root": "src",
    "qmd_root": "site",
    "generated_root": "site/_site",
    "source_suffix": ".clj",
    "qmd_suffix": ".qmd",
    "generated_suffix": ".html",
    "preview_base_url": "http://127.0.0.1:1971"
  },
  "commands": {
    "targeted_render": [
      "clojure -M:clay -A:markdown {source_relative}",
      "quarto render {qmd_relative}"
    ],
    "live_preview": "../.agents/scripts/vocabulary_preview.sh {source_relative}",
    "default_live_preview": "../.agents/scripts/vocabulary_preview.sh",
    "full_publication_gate": "quarto render site",
    "validation": [
      "clojure -M:test-clj",
      "clojure -M:test-cljs"
    ]
  },
  "browser_policy": {
    "browser": "codex-internal-browser",
    "protect_reading_tabs": true,
    "verification_tab": "separate",
    "checks": [
      "civitas-styling",
      "same-origin-navigation",
      "console-errors",
      "mobile-layout",
      "accessible-labels",
      "light-dark-contrast"
    ]
  }
}
